extends ../layout

block contenido
  h1= titulo

  if error
    .error-msg= error

  .info-message(style="background-color: #e7f3ff; border-left: 4px solid #2196F3; padding: 12px; margin-bottom: 20px; border-radius: 4px;")
    p(style="margin: 0;")
      strong 💡 Información: 
      | La nota de débito se aplicará al saldo del cliente. Puede agregar múltiples conceptos.

  form(action="/notas-debito/nuevo" method="POST" id="formNotaDebito")
    // Información de la Nota
    fieldset
      legend Datos de la Nota de Débito
      div(style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px;")
        div
          label(for="fechaEmision") Fecha de Emisión:
          input(type="date" name="fechaEmision" id="fechaEmision" required value=datos ? datos.fechaEmision : new Date().toISOString().split('T')[0])
        div
          label(for="clienteId") Cliente:
          select(name="clienteId" id="clienteId" required)
            option(value="") Seleccione un cliente
            each cliente in clientes
              option(value=cliente.id selected=(datos && datos.clienteId == cliente.id))
                | #{cliente.tipoDoc === 'DNI' ? cliente.nombre : cliente.razonSocial} - #{cliente.nroDoc}
        div
          label(for="puntoVenta") Punto de Venta:
          input(type="number" name="puntoVenta" id="puntoVenta" value=datos ? datos.puntoVenta : '1')
        div
          label(for="numero") Número de Nota:
          input(type="number" name="numero" id="numero" required value=datos ? datos.numero : '')
        div
          label(for="cae") CAE (Código Autorización):
          //- CAE con valor por defecto "123456789" pero editable
          input(type="text" name="cae" id="cae" value=datos && datos.cae ? datos.cae : '123456789')
        div
          label(for="fechaVtoCAE") Fecha Vto. CAE:
          //- Fecha Vto. CAE con valor por defecto (1 año a partir de hoy)
          - const hoy = new Date();
          - const unAnioDespues = new Date(hoy);
          - unAnioDespues.setFullYear(unAnioDespues.getFullYear() + 1);
          - const fechaVtoCAEDefault = unAnioDespues.toISOString().split('T')[0];
          input(type="date" name="fechaVtoCAE" id="fechaVtoCAE" value=datos && datos.fechaVtoCAE ? datos.fechaVtoCAE : fechaVtoCAEDefault)
        div
          label(for="fechaVencimiento") Fecha de Vencimiento:
          //- Fecha de vencimiento sin valor por defecto
          input(type="date" name="fechaVencimiento" id="fechaVencimiento" value=datos ? datos.fechaVencimiento : '')
        div
          label(for="facturaOrigenId") Factura Origen (opcional):
          select(name="facturaOrigenId" id="facturaOrigenId")
            option(value="") -- Seleccionar factura --
            each factura in facturas
              option(value=factura._id data-numero=factura.numero selected=(datos && datos.facturaOrigenId == factura._id))
                | #{factura.numero} - $#{factura.total.toLocaleString('es-AR', {minimumFractionDigits: 2})}
          input(type="hidden" name="facturaOrigenNumero" id="facturaOrigenNumero" value=datos ? datos.facturaOrigenNumero : '')

    // Conceptos - VERSIÓN TARJETAS (múltiples items)
    fieldset
      legend Conceptos de la Nota de Débito
      
      // Contenedor de tarjetas
      #conceptosContainer(style="display: flex; flex-direction: column; gap: 15px; margin-bottom: 20px;")
        // Tarjeta template (se clona para cada concepto)
        .concepto-card(style="border: 1px solid #ddd; border-radius: 8px; padding: 15px; background-color: #f9f9f9; position: relative;")
          button(type="button" onclick="eliminarConcepto(this)" style="position: absolute; top: 10px; right: 10px; background-color: #dc3545; color: white; border: none; border-radius: 50%; width: 30px; height: 30px; cursor: pointer; font-weight: bold;") ✕
          
          div(style="margin-bottom: 15px;")
            label(style="font-weight: bold; display: block; margin-bottom: 5px;") Descripción:
            input(type="text" name="conceptos[descripcion][]" required style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;" placeholder="Descripción del concepto")
          
          div(style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px;")
            div
              label(style="font-weight: bold; display: block; margin-bottom: 5px;") Precio Unitario:
              input(type="number" step="any" name="conceptos[precioUnitario][]" value="0" class="calcular" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;")
            div
              label(style="font-weight: bold; display: block; margin-bottom: 5px;") Alic. IVA:
              select(name="conceptos[alicIva][]" class="calcular-iva" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;")
                option(value="21%") 21%
                option(value="10.5%") 10.5%
                option(value="0%") 0%
            div
              label(style="font-weight: bold; display: block; margin-bottom: 5px;") Importe:
              input(type="text" name="conceptos[importe][]" readonly class="importe" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; background-color: #e9ecef; font-weight: bold;")
      
      // Botón para agregar concepto
      button(type="button" onclick="agregarConcepto()" style="padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; margin-top: 10px;")
        | + Agregar Concepto

      // Totales
      div(style="margin-top: 30px; padding: 20px; background-color: #f2f2f2; border-radius: 8px;")
        div(style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; max-width: 500px; margin-left: auto;")
          div
            label(style="font-weight: bold;") Otros Tributos:
            input(type="number" step="any" name="otrosTributos" id="otrosTributos" value="0" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;")
          div
            label(style="font-weight: bold;") Subtotal Neto:
            input(type="text" id="subtotalNeto" readonly style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; background-color: #e9ecef;")
          div
            label(style="font-weight: bold;") IVA 21%:
            input(type="text" id="iva21" readonly style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; background-color: #e9ecef;")
          div
            label(style="font-weight: bold;") IVA 10.5%:
            input(type="text" id="iva105" readonly style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc; background-color: #e9ecef;")
          div(style="grid-column: span 2;")
            label(style="font-weight: bold; font-size: 1.2rem;") TOTAL:
            input(type="text" name="total" id="total" readonly style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc; background-color: #e9ecef; font-size: 1.2rem; font-weight: bold; color: #dc3545;")

    // Observaciones
    fieldset
      legend Observaciones
      div
        label Observaciones:
        textarea(name="observaciones" rows="3" style="width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #ccc;")= datos ? datos.observaciones : ''

    div.form-actions(style="margin-top: 20px; text-align: center;")
      button(type="submit" style="padding: 12px 40px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px;") Generar Nota de Débito
      a(href="/notas-debito" style="display: inline-block; margin-left: 10px; padding: 12px 40px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px;") Cancelar

    block scripts
    script.
        // Función para recalcular todos los totales
        function recalcularTotales() {
        let subtotalNeto = 0;
        let iva21Total = 0;
        let iva105Total = 0;
        
        document.querySelectorAll('.concepto-card').forEach(card => {
            const precio = parseFloat(card.querySelector('input[name="conceptos[precioUnitario][]"]')?.value) || 0;
            const alicIva = card.querySelector('select[name="conceptos[alicIva][]"]')?.value || '21%';
            
            subtotalNeto += precio;
            if (alicIva === '21%') {
            iva21Total += precio * 0.21;
            } else if (alicIva === '10.5%') {
            iva105Total += precio * 0.105;
            }
            
            // Actualizar importe individual
            const importeInput = card.querySelector('input[name="conceptos[importe][]"]');
            if (importeInput) importeInput.value = precio.toLocaleString('es-AR', {minimumFractionDigits: 2});
        });
        
        const otrosTributos = parseFloat(document.getElementById('otrosTributos')?.value) || 0;
        const total = subtotalNeto + iva21Total + iva105Total + otrosTributos;
        
        document.getElementById('subtotalNeto').value = subtotalNeto.toLocaleString('es-AR', {minimumFractionDigits: 2});
        document.getElementById('iva21').value = iva21Total.toLocaleString('es-AR', {minimumFractionDigits: 2});
        document.getElementById('iva105').value = iva105Total.toLocaleString('es-AR', {minimumFractionDigits: 2});
        document.getElementById('total').value = total.toLocaleString('es-AR', {minimumFractionDigits: 2});
        }
        
        // Función para recalcular un concepto específico
        function recalcularConcepto(inputElement) {
        const card = inputElement.closest('.concepto-card');
        if (!card) return;
        
        const precio = parseFloat(card.querySelector('input[name="conceptos[precioUnitario][]"]')?.value) || 0;
        const alicIva = card.querySelector('select[name="conceptos[alicIva][]"]')?.value || '21%';
        
        const importeInput = card.querySelector('input[name="conceptos[importe][]"]');
        if (importeInput) importeInput.value = precio.toLocaleString('es-AR', {minimumFractionDigits: 2});
        
        recalcularTotales();
        }
        
        // Función para agregar nuevo concepto
        function agregarConcepto() {
        const container = document.getElementById('conceptosContainer');
        if (!container) return;
        
        const template = container.querySelector('.concepto-card');
        if (!template) return;
        
        const newCard = template.cloneNode(true);
        
        // Limpiar valores
        newCard.querySelectorAll('input').forEach(input => {
            if (input.type !== 'button') {
            input.value = '';
            }
        });
        
        const descripcionInput = newCard.querySelector('input[name="conceptos[descripcion][]"]');
        if (descripcionInput) descripcionInput.value = '';
        
        const precioInput = newCard.querySelector('input[name="conceptos[precioUnitario][]"]');
        if (precioInput) precioInput.value = '0';
        
        const importeInput = newCard.querySelector('input[name="conceptos[importe][]"]');
        if (importeInput) importeInput.value = '';
        
        const ivaSelect = newCard.querySelector('select[name="conceptos[alicIva][]"]');
        if (ivaSelect) ivaSelect.value = '21%';
        
        // Inicializar event listeners para la nueva tarjeta
        inicializarEventListenersTarjeta(newCard);
        
        container.appendChild(newCard);
        recalcularTotales();
        }
        
        // Función para eliminar concepto
        function eliminarConcepto(btn) {
        const card = btn.closest('.concepto-card');
        const container = document.getElementById('conceptosContainer');
        if (!container) return;
        
        if (container.querySelectorAll('.concepto-card').length > 1) {
            card.remove();
            recalcularTotales();
        } else {
            alert('Debe haber al menos un concepto en la nota de débito');
        }
        }
        
        // Función para recalcular desde el handler
        function recalcularConceptoHandler(event) {
        recalcularConcepto(event.target);
        }
        
        // Inicializar event listeners de una tarjeta
        function inicializarEventListenersTarjeta(card) {
        const calcularInputs = card.querySelectorAll('.calcular');
        calcularInputs.forEach(input => {
            input.removeEventListener('change', recalcularConceptoHandler);
            input.addEventListener('change', recalcularConceptoHandler);
        });
        
        const ivaSelects = card.querySelectorAll('.calcular-iva');
        ivaSelects.forEach(select => {
            select.removeEventListener('change', recalcularConceptoHandler);
            select.addEventListener('change', recalcularConceptoHandler);
        });
        }
        
        // Inicializar todas las tarjetas al cargar la página
        function inicializarTodasLasTarjetas() {
        const tarjetas = document.querySelectorAll('.concepto-card');
        tarjetas.forEach(tarjeta => {
            inicializarEventListenersTarjeta(tarjeta);
        });
        }
        
        // Autocompletar número de factura origen
        document.getElementById('facturaOrigenId')?.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const numero = selectedOption.getAttribute('data-numero') || '';
        document.getElementById('facturaOrigenNumero').value = numero;
        });
        
        document.addEventListener('DOMContentLoaded', function() {
        inicializarTodasLasTarjetas();
        
        const otrosTributos = document.getElementById('otrosTributos');
        if (otrosTributos) {
            otrosTributos.addEventListener('change', recalcularTotales);
        }
        
        recalcularTotales();
        });